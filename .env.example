# ============================================================
# LiveSafe — Environment Configuration Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ---- Frontend (Vite) ----
VITE_API_URL=http://localhost:3000/api
# Supabase (if used alongside self-hosted backend)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ---- Backend ----
PORT=3000
NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://livesafe_user:CHANGE_ME@localhost:5432/livesafe

# Auth — generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_64
JWT_EXPIRES_IN=7d

# Encryption — MUST be exactly 32 chars: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_EXACTLY_32_CHARS_HERE!

# CORS — comma-separated list of allowed origins in production
FRONTEND_URL=http://localhost:5173

# Rate limiting (requests per 15 min window per IP)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ---- Docker Postgres ----
POSTGRES_USER=livesafe_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=livesafe

# ---- Optional: Alerting / Monitoring ----
# SENTRY_DSN=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
